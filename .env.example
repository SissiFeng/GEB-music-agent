# Claudio AI DJ - Environment Variables
# Copy this file to .env and fill in your values

# Required: Telegram Bot Token
# Get from @BotFather: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Optional: ElevenLabs API Key (for premium voice)
# Note: Free tier API has limitations. Starter plan ($5/month) recommended.
# Get from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# Optional: Admin user ID for Telegram
# Get your ID from @userinfobot
ADMIN_USER_ID=your_telegram_user_id

# Optional: Webhook URL (for production deployment)
# WEBHOOK_URL=https://your-domain.com/webhook

# Optional: Netease Cloud Music API URL (default: localhost:3000)
NETEASE_API_URL=http://localhost:3000

# Optional: Moonshot API Key (alternative AI provider)
# MOONSHOT_API_KEY=your_moonshot_key_here
